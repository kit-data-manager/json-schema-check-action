{
  "name": "json-schema-check-action",
  "description": "Action for checking JSON schema validity and compatibility.",
  "version": "0.0.8",
  "author": "",
  "private": true,
  "homepage": "https://github.com/kit-data-manager/json-schema-check-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kit-data-manager/json-schema-check-action.git"
  },
  "bugs": {
    "url": "https://github.com/kit-data-manager/json-schema-check-action/issues"
  },
  "keywords": [
    "actions",
    "JSON"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/http-client": "^4.0.0",
    "@apidevtools/json-schema-ref-parser": "^15.1.1",
    "@rollup/plugin-json": "^6.1.0",
    "@types/json-diff": "^1.0.3",
    "ajv": "^8.17.1",
    "json-diff": "^1.0.6",
    "node-fetch": "^3.3.2",
    "rollup-plugin-typescript": "^1.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.3.0",
    "jest": "^30.0.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "rollup": "^4.53.2",
    "ts-jest": "^29.4.5",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "undici": ">=6.24.0"
  }
}
